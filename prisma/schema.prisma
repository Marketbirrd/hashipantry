generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           String    @id @default(cuid())
  name         String
  description  String
  imageUrl     String
  affiliateUrl String
  source       Source    @default(AMAZON)
  asin         String?
  category     String
  featured     Boolean   @default(false)
  dietTags     DietTag[] @relation("ProductDietTags")
  createdAt    DateTime  @default(now())
}

model DietTag {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[] @relation("ProductDietTags")
}

model Recipe {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  imageUrl    String
  prepTime    Int
  servings    Int      @default(2)
  difficulty  String   @default("Easy")
  excerpt     String
  ingredients Json
  steps       Json
  category    String
  dietTags    String[]
  publishedAt DateTime @default(now())
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  coverImage  String
  category    String
  publishedAt DateTime @default(now())
}

model DigitalProduct {
  id            String  @id @default(cuid())
  name          String
  description   String
  price         Int
  imageUrl      String
  fileKey       String
  stripePriceId String
  orders        Order[]
}

model Order {
  id              String         @id @default(cuid())
  email           String
  stripeSessionId String         @unique
  productId       String
  product         DigitalProduct @relation(fields: [productId], references: [id])
  downloadSentAt  DateTime?
  createdAt       DateTime       @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  name          String?
  password      String?
  image         String?
  dietPrefs     String[]
  createdAt     DateTime        @default(now())
  accounts      Account[]
  sessions      Session[]
  symptoms      SymptomEntry[]
  favorites     UserFavorite[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model SymptomEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  energy    Int
  mood      Int
  brainFog  Int
  joint     Int
  notes     String?
  createdAt DateTime @default(now())
}

model UserFavorite {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  productName String
  affiliateUrl String
  imageUrl    String?
  createdAt   DateTime @default(now())
  @@unique([userId, productId])
}

enum Source {
  AMAZON
  THRIVE
}
